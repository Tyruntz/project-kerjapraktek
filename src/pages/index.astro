---
const nomorMeja = Astro.url.searchParams.get("meja") || "1";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer";
import About from "../components/About";
import Kontak from "../components/Kontak";
import Partnership from "../components/Partnership";
import Navbar from "../components/navBar/Navbar";
---

<Layout title="Homepage">
  <main>
    <Navbar client:load nomorMeja={nomorMeja} />

    <!-- HERO -->
    <section id="home" class="hero">
      <div class="hero-bg"></div>
      <div class="hero-overlay"></div>
      <div class="hero-grain"></div>

      <div class="hero-inner">
        <!-- Left content -->
        <div class="hero-content">
          <div class="hero-eyebrow">
            <span class="hero-eyebrow-line"></span>
            Est. 2023 · Pontianak
            <span class="hero-eyebrow-line"></span>
          </div>

          <h1 class="hero-headline">
            <span class="hero-h-sub">Welcome to</span>
            <span class="hero-h-main">Jima</span>
            <span class="hero-h-accent">Coffee House</span>
          </h1>

          <p class="hero-tagline">
            Inspirasi datang dari<br/>secangkir kopi buatan hati
          </p>

          <div class="hero-divider"></div>

          <div class="hero-ctas">
            <a class="hero-btn-primary" href={`/menu?meja=${nomorMeja}`}>
              <span>Order Now</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a class="hero-btn-secondary" href="/reservasi">
              Reservasi Meja
            </a>
          </div>
        </div>

        <!-- Right badge -->
        <div class="hero-badge-wrap">
          <div class="hero-badge">
            <div class="hero-badge-ring"></div>
            <div class="hero-badge-inner">
              <div class="hero-badge-icon">☕</div>
              <div class="hero-badge-text">Premium</div>
              <div class="hero-badge-text2">Coffee</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom info strip -->
      <div class="hero-strip">
        <div class="hero-strip-inner">
          <div class="hero-strip-item">
            <span class="hero-strip-num">100%</span>
            <span class="hero-strip-label">Premium Beans</span>
          </div>
          <div class="hero-strip-sep"></div>
          <div class="hero-strip-item">
            <span class="hero-strip-num">2023</span>
            <span class="hero-strip-label">Est. Year</span>
          </div>
          <div class="hero-strip-sep"></div>
          <div class="hero-strip-item">
            <span class="hero-strip-num">∞</span>
            <span class="hero-strip-label">Happy Cups</span>
          </div>
          <div class="hero-strip-sep"></div>
          <div class="hero-strip-item">
            <span class="hero-strip-num">08.00</span>
            <span class="hero-strip-label">Open Daily</span>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="hero-scroll">
        <div class="hero-scroll-line"></div>
        <span class="hero-scroll-label">Scroll</span>
      </div>
    </section>

    <section id="about" class="section-about">
      <About client:load />
    </section>

    <section id="partner">
      <Partnership client:load />
    </section>

    <section id="contact">
      <Kontak client:load />
    </section>

    <Footer client:load />
  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@400;500;600;700&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  main { display: flex; flex-direction: column; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    font-family: 'Montserrat', sans-serif;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background: url("https://ujchqhvrzsuscnkdwvyi.supabase.co/storage/v1/object/public/images/images/JIMA_POST.png") center/cover no-repeat;
    transform: scale(1.05);
    animation: heroZoom 12s ease-out forwards;
  }
  @keyframes heroZoom {
    from { transform: scale(1.08); }
    to   { transform: scale(1.0); }
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10,8,6,0.88) 0%,
      rgba(10,8,6,0.60) 50%,
      rgba(10,8,6,0.40) 100%
    );
  }

  .hero-grain {
    position: absolute; inset: 0; pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.5;
  }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1280px; margin: 0 auto;
    padding: 120px 60px 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
    flex: 1;
  }

  /* Content */
  .hero-content { max-width: 580px; }

  .hero-eyebrow {
    display: flex; align-items: center; gap: 12px;
    font-size: 8px; letter-spacing: 5px; text-transform: uppercase;
    color: rgba(212,168,83,0.7); font-weight: 600;
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease both;
  }
  .hero-eyebrow-line {
    flex: 1; max-width: 40px; height: 1px;
    background: rgba(212,168,83,0.3);
  }

  .hero-headline {
    display: flex; flex-direction: column;
    gap: 0; margin-bottom: 24px;
    animation: fadeUp 0.8s 0.15s ease both;
  }
  .hero-h-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(12px, 1.5vw, 16px);
    font-weight: 400; letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 4px;
  }
  .hero-h-main {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(72px, 12vw, 130px);
    font-weight: 300; color: #fff;
    line-height: 0.9; letter-spacing: -2px;
  }
  .hero-h-accent {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(18px, 2.5vw, 26px);
    font-weight: 300; font-style: italic;
    color: #d4a853; letter-spacing: 4px;
    margin-top: 4px;
  }

  .hero-tagline {
    font-size: clamp(13px, 1.5vw, 15px);
    line-height: 1.7; color: rgba(255,255,255,0.45);
    margin-bottom: 32px;
    animation: fadeUp 0.8s 0.3s ease both;
  }

  .hero-divider {
    width: 48px; height: 1px;
    background: linear-gradient(to right, #d4a853, transparent);
    margin-bottom: 32px;
    animation: fadeUp 0.8s 0.35s ease both;
  }

  .hero-ctas {
    display: flex; gap: 12px; flex-wrap: wrap;
    animation: fadeUp 0.8s 0.45s ease both;
  }
  .hero-btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 15px 32px;
    background: linear-gradient(135deg, #b8651a, #d4a853);
    color: #fff; text-decoration: none;
    font-size: 10px; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; border-radius: 2px;
    transition: all 0.3s;
  }
  .hero-btn-primary:hover {
    box-shadow: 0 12px 40px rgba(184,101,26,0.45);
    transform: translateY(-2px);
  }
  .hero-btn-secondary {
    display: inline-flex; align-items: center;
    padding: 15px 32px;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7); text-decoration: none;
    font-size: 10px; font-weight: 600; letter-spacing: 2px;
    text-transform: uppercase; border-radius: 2px;
    transition: all 0.3s;
  }
  .hero-btn-secondary:hover {
    border-color: #d4a853; color: #d4a853;
    background: rgba(212,168,83,0.06);
  }

  /* Badge */
  .hero-badge-wrap {
    flex-shrink: 0;
    animation: fadeIn 1.2s 0.6s ease both;
  }
  .hero-badge {
    width: 180px; height: 180px;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    animation: rotateSlow 30s linear infinite;
  }
  @keyframes rotateSlow { to { transform: rotate(360deg); } }
  .hero-badge-ring {
    position: absolute; inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(212,168,83,0.25);
    background: conic-gradient(
      from 0deg,
      rgba(212,168,83,0.08) 0%,
      rgba(212,168,83,0.02) 50%,
      rgba(212,168,83,0.08) 100%
    );
  }
  .hero-badge-inner {
    animation: rotateSlow 30s linear infinite reverse;
    display: flex; flex-direction: column;
    align-items: center; gap: 4px;
    text-align: center;
  }
  .hero-badge-icon { font-size: 32px; margin-bottom: 4px; }
  .hero-badge-text {
    font-size: 9px; letter-spacing: 4px; text-transform: uppercase;
    color: #d4a853; font-weight: 700;
  }
  .hero-badge-text2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px; font-weight: 300; color: rgba(255,255,255,0.6);
    letter-spacing: 2px;
  }

  /* Strip */
  .hero-strip {
    position: relative; z-index: 2;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(10,8,6,0.6);
    backdrop-filter: blur(10px);
  }
  .hero-strip-inner {
    max-width: 1280px; margin: 0 auto;
    padding: 24px 60px;
    display: flex; align-items: center; gap: 0;
    flex-wrap: wrap;
  }
  .hero-strip-item {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; gap: 4px; padding: 8px 20px;
    min-width: 100px;
  }
  .hero-strip-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px; font-weight: 300;
    color: #d4a853; line-height: 1;
  }
  .hero-strip-label {
    font-size: 8px; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(255,255,255,0.3);
    font-weight: 600;
  }
  .hero-strip-sep {
    width: 1px; height: 40px;
    background: rgba(255,255,255,0.08);
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute; right: 40px; bottom: 100px;
    z-index: 2;
    display: flex; flex-direction: column;
    align-items: center; gap: 8px;
  }
  .hero-scroll-line {
    width: 1px; height: 60px;
    background: linear-gradient(to bottom, rgba(212,168,83,0.6), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); transform-origin: top; }
  }
  .hero-scroll-label {
    font-size: 7px; letter-spacing: 3px;
    text-transform: uppercase; color: rgba(255,255,255,0.25);
    writing-mode: vertical-rl;
  }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Section */
  .section-about { background: #fff; }

  /* Responsive */
  @media(max-width: 900px) {
    .hero-inner { padding: 100px 24px 40px; flex-direction: column; align-items: flex-start; }
    .hero-badge-wrap { display: none; }
    .hero-strip-inner { padding: 20px 24px; }
    .hero-scroll { display: none; }
  }
  @media(max-width: 480px) {
    .hero-strip-sep { display: none; }
    .hero-strip-item { min-width: 80px; }
  }
</style>
